{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Profile Switcher",
  "version": "1.0.0",
  "identifier": "com.changtaowang.codex-profile-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Profile Switcher",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
